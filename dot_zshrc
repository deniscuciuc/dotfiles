# ── SAFE BACKUP FUNCTION (FIXED) ───────────────────────
rbhome() {
  if [ ! -f "$RESTIC_TARGETS" ]; then
    echo "❌ Missing targets file: $RESTIC_TARGETS"
    return 1
  fi

  if [ ! -f "$RESTIC_EXCLUDES" ]; then
    echo "❌ Missing excludes file: $RESTIC_EXCLUDES"
    return 1
  fi

  if ! mountpoint -q /mnt/backup/workstation; then
    echo "❌ Backup disk not mounted!"
    return 1
  fi

  echo "✔ Running Restic backup..."

  # convert each line into absolute path safely
  targets=()

  while IFS= read -r line; do
    # skip empty lines and comments
    [[ -z "$line" || "$line" == \#* ]] && continue

    # expand ONLY ~ safely
    expanded="${line/#\~/$HOME}"

    if [ -e "$expanded" ]; then
      targets+=("$expanded")
    else
      echo "⚠️ Skipping missing: $expanded"
    fi
  done < "$RESTIC_TARGETS"

  if [ ${#targets[@]} -eq 0 ]; then
    echo "❌ No valid backup sources found"
    return 1
  fi

  restic backup "${targets[@]}" \
    --one-file-system \
    --compression auto \
    --exclude-file "$RESTIC_EXCLUDES"
}

# ── CLEANUP ────────────────────────────────────────────
rcleanup() {
  restic forget \
    --keep-daily 7 \
    --keep-weekly 4 \
    --keep-monthly 12 \
    --prune
}

# ── FULL MAINTENANCE ───────────────────────────────────
rmaint() {
  rbhome && rcleanup && rc
}

# ── RESTORE ────────────────────────────────────────────
rrestore() {
  if [ -z "$1" ]; then
    echo "Usage: rrestore <snapshot-id|latest>"
    return 1
  fi

  restic restore "$1" --target /tmp/restic-restore
}

