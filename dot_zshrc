        COPILOT_PROVIDER_BASE_URL \
        COPILOT_PROVIDER_API_KEY \
        COPILOT_MODEL \
        COPILOT_PROVIDER_MAX_PROMPT_TOKENS \
        COPILOT_PROVIDER_MAX_OUTPUT_TOKENS

